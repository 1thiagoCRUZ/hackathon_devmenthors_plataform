{
  "info": {
    "name": "Hackathon Forms API",
    "description": "Coleção completa com todas as rotas da API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Autenticação",
      "item": [
        {
          "name": "1. Register Admin",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin Organizador\",\n  \"email\": \"admin@hackathon.com\",\n  \"password\": \"senha123\",\n  \"role\": \"ADMIN\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "1.2 Register Jurado",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"João Jurado\",\n  \"email\": \"jurado@hackathon.com\",\n  \"password\": \"senha123\",\n  \"role\": \"JUDGE\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "1.3 Register Dev",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Carlos Dev\",\n  \"email\": \"dev@hackathon.com\",\n  \"password\": \"senha123\",\n  \"role\": \"DEV\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": ["{{base_url}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "2. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set(\"token\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@hackathon.com\",\n  \"password\": \"senha123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Formulários",
      "item": [
        {
          "name": "1. Criar Form (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Hackathon Nacional 2026\",\n  \"slug\": \"hack-2026\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/forms",
              "host": ["{{base_url}}"],
              "path": ["forms"]
            }
          }
        },
        {
          "name": "2. Listar Forms",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/forms",
              "host": ["{{base_url}}"],
              "path": ["forms"]
            }
          }
        },
        {
          "name": "3. Fechar/Abrir Form (ADMIN)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isOpen\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/forms/:id/toggle",
              "host": ["{{base_url}}"],
              "path": ["forms", ":id", "toggle"],
              "variable": [
                {
                  "key": "id",
                  "value": "INSERIR_ID_AQUI"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Submissão (Projetos)",
      "item": [
        {
          "name": "1. Enviar Projeto (FormData)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "projectName", "value": "Projeto Revolucionário", "type": "text" },
                { "key": "description", "value": "Um projeto incrível que resolve tudo.", "type": "text" },
                { "key": "leaderEmail", "value": "lider@teste.com", "type": "text" },
                { "key": "teamMembers", "value": "[{\"name\": \"Dev\"}, {\"name\": \"Designer\"}]", "type": "text" },
                { "key": "links", "value": "[\"https://github.com/repo\"]", "type": "text" },
                { "key": "files", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{base_url}}/forms/:slug/submissions",
              "host": ["{{base_url}}"],
              "path": ["forms", ":slug", "submissions"],
              "variable": [
                {
                  "key": "slug",
                  "value": "INSERIR_SLUG_DO_FORM_AQUI"
                }
              ]
            }
          }
        },
        {
          "name": "2. Listar Projetos Aprovados",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/forms/:slug/submissions",
              "host": ["{{base_url}}"],
              "path": ["forms", ":slug", "submissions"],
              "variable": [
                {
                  "key": "slug",
                  "value": "INSERIR_SLUG_DO_FORM_AQUI"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Avaliação e Ranking",
      "item": [
        {
          "name": "1. Dar Nota (ADMIN, JUDGE, DEV)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"submissionId\": \"INSERIR_SUBMISSION_ID_AQUI\",\n  \"criterionInnovation\": 9.5,\n  \"criterionDesign\": 8.0,\n  \"criterionTechnical\": 10,\n  \"notes\": \"Excelente arquitetura e apresentação\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/evaluations",
              "host": ["{{base_url}}"],
              "path": ["evaluations"]
            }
          }
        },
        {
          "name": "2. Ver Ranking do Form",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/evaluations/ranking/:formId",
              "host": ["{{base_url}}"],
              "path": ["evaluations", "ranking", ":formId"],
              "variable": [
                {
                  "key": "formId",
                  "value": "INSERIR_FORM_ID_AQUI"
                }
              ]
            }
          }
        },
        {
          "name": "3. Progresso de Votação (Dashboard)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}", "type": "text" }
            ],
            "url": {
              "raw": "{{base_url}}/forms/:slug/voting-progress",
              "host": ["{{base_url}}"],
              "path": ["forms", ":slug", "voting-progress"],
              "variable": [
                {
                  "key": "slug",
                  "value": "INSERIR_SLUG_DO_FORM_AQUI"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
