{
  "name": "forms-hackathon-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "postinstall": "npm run install:backend && npm run install:frontend",
    "install:backend": "cd dev-forms-backend && npm install",
    "install:frontend": "cd front-hackathon && npm install",
    "dev:backend": "cd dev-forms-backend && npm run dev",
    "dev:frontend": "cd front-hackathon && npm run dev",
    "dev": "concurrently -c \"blue,green\" \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
